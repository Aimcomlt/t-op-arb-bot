{
  "name": "t-op-arb-bot",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "backend",
    "frontend",
    "packages/types",
    "packages/core"
  ],
  "scripts": {
    "dev": "concurrently \"pnpm --filter backend dev\" \"pnpm --filter frontend dev\"",
    "build": "pnpm run build:ts && pnpm --filter ./frontend build",
    "build:ts": "tsc -b tsconfig.build.json",
    "clean": "rimraf packages/**/dist backend/dist",
    "typecheck": "tsc -b tsconfig.build.json --pretty",
    "lint": "pnpm -r lint || echo \"no lint scripts\"",
    "test": "pnpm -r test || echo \"no test scripts\"",
    "format": "pnpm -r format || echo \"no format scripts\"",
    "prepare": "husky install"
  },
  "devDependencies": {
    "concurrently": "^9.2.0",
    "cross-env": "^10.0.0",
    "husky": "^9.1.7",
    "prettier": "^3.6.2",
    "rimraf": "^6.0.1",
    "typescript": "^5.5.4",
    "ws": "^8.18.3"
  },
  "pnpm": {
    "overrides": {
      "zod": "^3.23.8"
    }
  },
  "packageManager": "pnpm@9.15.9+sha512.68046141893c66fad01c079231128e9afb89ef87e2691d69e4d40eee228988295fd4682181bae55b58418c3a253bde65a505ec7c5f9403ece5cc3cd37dcf2531"
}
